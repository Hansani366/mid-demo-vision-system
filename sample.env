# Copy this to .env and fill in your values

# ── VLM Backend ───────────────────────────────────────────────────────────────
# Set in docker-compose.yml → vlm-service → environment → VLM_BACKEND
# Options: gemini | moondream

# ── Gemini (required only when VLM_BACKEND=gemini) ───────────────────────────
GOOGLE_API_KEY=your_google_api_key_here